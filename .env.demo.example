# Ensyncro — DEMO environment template
# Seeded, clearly-not-live data. All 3 roles instantly accessible.
# Set these values in the Vercel "demo" environment (or copy to .env locally).

APP_ENV=demo
NODE_ENV=production

# Injected by Vercel's Neon integration — leave blank here.
DATABASE_URL=
DIRECT_URL=

API_PORT=3000
CORS_ORIGIN=https://demo.ensyncro.app

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Demo uses a mock OTP (any code accepted / fixed code) — no SMS provider.
OTP_MODE=mock
