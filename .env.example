# ─────────────────────────────────────────────────────────────
# Ensyncro — environment template
# Copy to `.env` for local dev, or set these in your host
# (Vercel per-environment settings) for demo/staging/production.
# Never commit a filled-in copy — only *.example files are tracked.
# ─────────────────────────────────────────────────────────────

# Which environment this process is running as: demo | staging | production
APP_ENV=demo
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
# DO NOT hardcode a connection string here.
# Vercel's Neon integration injects DATABASE_URL per environment
# once the project is connected. Leave blank locally unless you
# are pointing at your own local Postgres.
DATABASE_URL=

# Optional: a direct (non-pooled) URL if using Prisma migrations
# against a pooled Neon endpoint. Also injected by the integration.
DIRECT_URL=

# ── API ──────────────────────────────────────────────────────
API_PORT=3000
# Comma-separated list of origins allowed to call the API
CORS_ORIGIN=http://localhost:4200

# ── Auth (JWT) ───────────────────────────────────────────────
# Generate strong random values per environment. Do not reuse.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ── OTP (mock in demo/staging, real provider in production) ───
OTP_MODE=mock
