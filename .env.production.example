# Ensyncro — PRODUCTION environment template
# Real OTP delivery, security-hardened. Stats use qualitative framing until
# thresholds are crossed (proposed: 25+ founders, 10+ investors), then live counts.
# Set these values in the Vercel "production" environment.

APP_ENV=production
NODE_ENV=production

# Injected by Vercel's Neon integration — leave blank here.
DATABASE_URL=
DIRECT_URL=

API_PORT=3000
CORS_ORIGIN=https://ensyncro.app

# Generate strong, unique secrets. Never reuse across environments.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Production requires a real OTP/SMS provider (phase 2).
OTP_MODE=live
