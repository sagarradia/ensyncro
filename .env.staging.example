# Ensyncro — STAGING environment template
# Real schema, real auth, seeded data. Used for QA and pitch-deck screenshots.
# Homepage stats pull real numbers from platform_stats (this is what staging tests).
# Set these values in the Vercel "staging" environment.

APP_ENV=staging
NODE_ENV=production

# Injected by Vercel's Neon integration — leave blank here.
DATABASE_URL=
DIRECT_URL=

API_PORT=3000
CORS_ORIGIN=https://staging.ensyncro.app

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Staging can still use mock OTP until a provider is wired up.
OTP_MODE=mock
