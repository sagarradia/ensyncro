// Ensyncro — Prisma schema
// Connection string is read from the DATABASE_URL environment variable.
// It is NOT hardcoded: Vercel's Neon integration injects it per environment
// (demo / staging / production). See the repo README for details.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl is used for migrations when DATABASE_URL points at a pooled
  // (PgBouncer/Neon) endpoint. Also injected by the Neon integration.
  directUrl = env("DIRECT_URL")
}

