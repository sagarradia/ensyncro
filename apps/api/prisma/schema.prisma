// Ensyncro — Prisma schema
// Connection string is read from the DATABASE_URL environment variable.
// It is NOT hardcoded: Vercel's Neon integration injects it. See DEPLOYMENT.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl is the unpooled endpoint, used for migrations.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth (task #5)
// ─────────────────────────────────────────────────────────────

enum Role {
  FOUNDER
  INVESTOR
  ADMIN
}

/// Admin sub-roles (PRD §3). Held on AdminProfile; admins are invite-only.
enum AdminRole {
  SUPER
  FINANCE
  LEGAL
  OPS
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum OtpChannel {
  EMAIL
  MOBILE
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  mobile         String?    @unique
  passwordHash   String
  role           Role
  status         UserStatus @default(PENDING_VERIFICATION)
  emailVerified  Boolean    @default(false)
  mobileVerified Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  otpCodes      OtpCode[]
  refreshTokens RefreshToken[]

  founderProfile  FounderProfile?
  investorProfile InvestorProfile?
  adminProfile    AdminProfile?

  dataRoomFiles DataRoomFile[]
  dataRoomViews DataRoomAccessLog[]

  sectionViewsOfMine ProfileSectionAccessLog[] @relation("SectionLogFounder")
  sectionViewsMade   ProfileSectionAccessLog[] @relation("SectionLogViewer")

  shortlistsMade    SavedShortlist[] @relation("ShortlistInvestor")
  shortlistedAs     SavedShortlist[] @relation("ShortlistFounder")
  introRequestsSent IntroRequest[]   @relation("IntroFrom")
  introRequestsRecv IntroRequest[]   @relation("IntroTo")

  cmsUpdates       CmsContent[]
  adminInvitesSent AdminInvite[]     @relation("InviteCreatedBy")

  @@map("users")
}

model OtpCode {
  id         String     @id @default(uuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    OtpChannel
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, channel])
  @@map("otp_codes")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// Profiles (tasks #7 / #8 / #9) — PRD §7
// ─────────────────────────────────────────────────────────────

/// Company stage for a founder raising capital.
enum FundingStage {
  IDEA
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C_PLUS
}

/// Investor types (PRD §3) — multi-select on InvestorProfile.
enum InvestorType {
  ANGEL
  PRE_SEED
  SEED_VC
  SERIES_A_PLUS_VC
  MICRO_VC
  SYNDICATE
  CROWDFUNDING
  CORPORATE_VC
  FAMILY_OFFICE
  ACCELERATOR_INCUBATOR
  GOVERNMENT_INSTITUTIONAL
}

/// Where an externally hosted pitch video lives. Only the provider and the
/// video id are stored — the embed URL is rebuilt by us, so a founder-supplied
/// URL is never reflected straight into an iframe.
enum VideoProvider {
  YOUTUBE
  VIMEO
  LOOM
}

model FounderProfile {
  id            String       @id @default(uuid())
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  sector        String
  stage         FundingStage
  /// Amount sought, whole currency units (no cents).
  fundingSought Int?
  description   String?
  website       String?
  location      String?
  teamSize      Int?
  /// Set true when the onboarding wizard is finished.
  completed     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // ── Media ────────────────────────────────────────────────────
  /// A pitch video is either hosted elsewhere (provider + id) or uploaded
  /// (pitchVideoFile). Not both — the API clears one when the other is set.
  pitchVideoProvider VideoProvider?
  pitchVideoId       String?
  pitchVideoFileId   String?        @unique
  pitchVideoFile     DataRoomFile?  @relation("FounderPitchVideo", fields: [pitchVideoFileId], references: [id], onDelete: SetNull)

  // ── Public product page ──────────────────────────────────────
  productName        String?
  tagline            String?
  productDescription String?
  /// Free-form category tags, extending the single `sector` field.
  categories         String[]
  logoFileId         String?       @unique
  logoFile           DataRoomFile? @relation("FounderLogo", fields: [logoFileId], references: [id], onDelete: SetNull)

  // ── Gated commercial detail ──────────────────────────────────
  /// Whole currency units per month / per year.
  mrr             Int?
  arr             Int?
  monthlyBurn     Int?
  runwayMonths    Int?
  useOfFunds      String?
  /// Reuses the data room's visibility model so gating behaves identically.
  financialsVisibility     DataRoomVisibility @default(PRIVATE)
  fundingHistoryVisibility DataRoomVisibility @default(PRIVATE)

  milestones    FounderMilestone[]
  fundingRounds FundingRound[]

  @@index([sector])
  @@index([stage])
  @@map("founder_profiles")
}

/// Traction timeline shown alongside financials, and gated with them.
model FounderMilestone {
  id          String         @id @default(uuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)
  title       String
  description String?
  /// When it happened, or is expected to.
  occurredOn  DateTime
  achieved    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([founderId])
  @@map("founder_milestones")
}

/// One closed round in the founder's funding history.
model FundingRound {
  id            String         @id @default(uuid())
  founderId     String
  founder       FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)
  stage         FundingStage
  /// Whole currency units.
  amountRaised  Int
  preMoney      Int?
  postMoney     Int?
  closedOn      DateTime
  /// Optional free text — not a link to an InvestorProfile on purpose, since
  /// most historical leads will not be users of the platform.
  leadInvestor  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([founderId])
  @@map("funding_rounds")
}

/// Which gated profile section a viewer opened. The data room audits file
/// views; this is the equivalent for financials and funding history.
enum ProfileSection {
  FINANCIALS
  FUNDING_HISTORY
}

model ProfileSectionAccessLog {
  id        String         @id @default(uuid())
  founderId String
  founder   User           @relation("SectionLogFounder", fields: [founderId], references: [id], onDelete: Cascade)
  viewerId  String
  viewer    User           @relation("SectionLogViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  section   ProfileSection
  viewedAt  DateTime       @default(now())

  @@index([founderId])
  @@index([viewerId])
  @@map("profile_section_access_log")
}

model InvestorProfile {
  id            String         @id @default(uuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Fund name, or the individual's name for angels.
  name          String
  investorTypes InvestorType[]
  sectors       String[]
  /// Ticket size range, whole currency units.
  ticketMin     Int?
  ticketMax     Int?
  description   String?
  website       String?
  location      String?
  completed     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("investor_profiles")
}

model AdminProfile {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminRole AdminRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admin_profiles")
}

/// Invite-only admin creation (task #9). Token is stored hashed.
model AdminInvite {
  id          String    @id @default(uuid())
  email       String
  adminRole   AdminRole
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdById String?
  createdBy   User?     @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([email])
  @@map("admin_invites")
}

// ─────────────────────────────────────────────────────────────
// Data room (tasks #12 / #13) — PRD §4: no file is ever reachable
// by a public URL; access is checked then served via signed URL.
// ─────────────────────────────────────────────────────────────

enum DataRoomVisibility {
  PRIVATE
  SHARED_ON_REQUEST
  VISIBLE_TO_INVESTORS
}

/// What a stored file is, which decides its size cap and whether it counts
/// against the founder's storage quota. Everything shares one storage,
/// permission and audit pipeline; only the limits differ.
enum MediaKind {
  DOCUMENT
  PITCH_VIDEO
  PRODUCT_IMAGE
  LOGO
}

/// Direct-to-S3 uploads exist as a row before their bytes do: the row is
/// created to mint a presigned PUT, then confirmed once the object is
/// verified in the bucket. Rows that are never confirmed stay PENDING and are
/// invisible to every read path.
enum UploadStatus {
  PENDING
  READY
}

model DataRoomFile {
  id          String             @id @default(uuid())
  ownerId     String
  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Key in private object storage — never a public URL.
  fileKey     String             @unique
  fileName    String
  contentType String?
  sizeBytes   Int?
  visibility  DataRoomVisibility @default(PRIVATE)
  kind        MediaKind          @default(DOCUMENT)
  /// Defaults to READY so anything written by the multipart path (and every
  /// pre-existing row) is immediately usable; the presigned flow sets PENDING.
  status      UploadStatus       @default(READY)
  uploadedAt  DateTime           @default(now())

  accessLogs DataRoomAccessLog[]
  blob       DataRoomFileBlob?
  /// Set when this file is the founder's pitch video or logo.
  pitchVideoFor FounderProfile? @relation("FounderPitchVideo")
  logoFor       FounderProfile? @relation("FounderLogo")

  @@index([ownerId])
  @@index([ownerId, kind])
  @@map("data_room_files")
}

/// File bytes, kept in a separate table so listing files never pulls blobs.
/// Interim backend: PRD §8 specifies S3-compatible private storage. The
/// StorageService interface isolates this, so swapping to S3 is one
/// implementation change with no effect on the permission/signed-URL layer.
model DataRoomFileBlob {
  fileId  String       @id
  file    DataRoomFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  content Bytes

  @@map("data_room_file_blobs")
}

model DataRoomAccessLog {
  id       String       @id @default(uuid())
  fileId   String
  file     DataRoomFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  viewerId String
  viewer   User         @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt DateTime     @default(now())

  @@index([fileId])
  @@index([viewerId])
  @@map("data_room_access_log")
}

// ─────────────────────────────────────────────────────────────
// Discovery (task #11)
// ─────────────────────────────────────────────────────────────

enum ShortlistStatus {
  SAVED
  CONTACTED
  ARCHIVED
}

/// Investor -> founder shortlist ("matches / saved_shortlist" in PRD §7).
model SavedShortlist {
  id         String          @id @default(uuid())
  investorId String
  investor   User            @relation("ShortlistInvestor", fields: [investorId], references: [id], onDelete: Cascade)
  founderId  String
  founder    User            @relation("ShortlistFounder", fields: [founderId], references: [id], onDelete: Cascade)
  status     ShortlistStatus @default(SAVED)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([investorId, founderId])
  @@index([founderId])
  @@map("saved_shortlist")
}

enum IntroRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

/// PRD §10 decision: threaded messaging is NOT in v1 — it is replaced by a
/// lightweight "Request intro" action (notification + email). So there is
/// deliberately no `messages` table; this models the v1 behaviour instead.
/// Full messaging is deferred to phase 2.
model IntroRequest {
  id         String             @id @default(uuid())
  fromUserId String
  fromUser   User               @relation("IntroFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User               @relation("IntroTo", fields: [toUserId], references: [id], onDelete: Cascade)
  status     IntroRequestStatus @default(PENDING)
  note       String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([fromUserId])
  @@index([toUserId])
  @@map("intro_requests")
}

// ─────────────────────────────────────────────────────────────
// CMS + marketing stats (tasks #14 / #16)
// ─────────────────────────────────────────────────────────────

/// Editable homepage/marketing copy and pricing tiers (PRD §6).
model CmsContent {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("cms_content")
}

/// Live counters for the homepage (PRD §6 / §10).
model PlatformStat {
  id         String   @id @default(uuid())
  metricName String   @unique
  value      Int      @default(0)
  computedAt DateTime @default(now())

  @@map("platform_stats")
}
